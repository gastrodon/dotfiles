#!/usr/bin/env bash
set -euo pipefail

export NIXPKGS_ALLOW_UNFREE=1
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

case "${1:-build}" in
  build)
    nixos-rebuild build --flake "$SCRIPT_DIR#twink" --impure
    ;;
  switch)
    nixos-rebuild switch --flake "$SCRIPT_DIR#twink" --impure
    ;;
  *)
    echo "Usage: sudo $0 [build|switch]"
    echo "  build  - Build configuration (default)"
    echo "  switch - Copy files to /etc/nixos and switch"
    exit 1
    ;;
esac

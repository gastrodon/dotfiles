#!/usr/bin/env bash
set -euo pipefail

export NIXPKGS_ALLOW_UNFREE=1
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

HOSTNAME="${2:-${NIXOS_HOSTNAME:-$(hostname)}}"

case "${1:-build}" in
  build)
    if [[ "$HOSTNAME" != "stone" && "$HOSTNAME" != "twink" && "$HOSTNAME" != "server" ]]; then
      echo "Error: Unknown hostname '$HOSTNAME'"
      echo "Set NIXOS_HOSTNAME=stone|twink|server to build for a specific host"
      exit 1
    fi
    echo "Building configuration for $HOSTNAME..."
    nixos-rebuild build --flake "$SCRIPT_DIR#$HOSTNAME" --impure
    ;;
  switch)
    if [[ "$HOSTNAME" != "stone" && "$HOSTNAME" != "twink" && "$HOSTNAME" != "server" ]]; then
      echo "Error: Unknown hostname '$HOSTNAME'"
      echo "Set NIXOS_HOSTNAME=stone|twink|server to switch a specific host"
      exit 1
    fi
    echo "Switching to configuration for $HOSTNAME..."
    nixos-rebuild switch --flake "$SCRIPT_DIR#$HOSTNAME" --impure
    i3-msg restart 2>/dev/null || true
    ;;
  iso)
    if [[ -z "${2:-}" ]]; then
      echo "Error: iso requires --auto or --live flag"
      echo "Usage: $0 iso [--auto | --live] [hostname]"
      exit 1
    fi

    ISO_MODE="$2"
    HOSTNAME="${3:-${NIXOS_HOSTNAME:-$(hostname)}}"

    case "$ISO_MODE" in
      --auto)
        if [[ "$HOSTNAME" != "stone" && "$HOSTNAME" != "twink" && "$HOSTNAME" != "server" ]]; then
          echo "Error: Unknown hostname '$HOSTNAME'"
          echo "Set NIXOS_HOSTNAME=stone|twink|server to build an ISO for a specific host"
          exit 1
        fi
        echo "Building autoinstall ISO for $HOSTNAME..."
        nix build "$SCRIPT_DIR#nixosConfigurations.${HOSTNAME}-installer.config.system.build.isoImage" --impure
        echo "ISO at: $(readlink result)/iso/"
        ;;
      --live)
        if [[ "$HOSTNAME" != "server" ]]; then
          echo "Error: --live is only supported for server hostname"
          exit 1
        fi
        echo "Building live-media ISO for $HOSTNAME..."
        nix build "$SCRIPT_DIR#nixosConfigurations.${HOSTNAME}-live-media.config.system.build.isoImage" --impure
        echo "ISO at: $(readlink result)/iso/"
        echo ""
        echo "To dd onto USB media:"
        echo "  dd if=$(readlink result)/iso/*.iso of=/dev/sdX bs=4M status=progress"
        echo "  (replace /dev/sdX with your USB device)"
        ;;
      *)
        echo "Error: Unknown ISO mode '$ISO_MODE'"
        echo "Usage: $0 iso [--auto | --live] [hostname]"
        exit 1
        ;;
    esac
    ;;
  sdimage)
    if [[ "$HOSTNAME" != "rpi2b" && "$HOSTNAME" != "rpi3b-plus" && "$HOSTNAME" != "rpi4b" ]]; then
      echo "Error: Unknown hostname '$HOSTNAME'"
      echo "Set NIXOS_HOSTNAME=rpi2b|rpi3b-plus|rpi4b to build an SD image for a specific target"
      exit 1
    fi
    echo "Building SD image for $HOSTNAME..."
    nix build "$SCRIPT_DIR#nixosConfigurations.${HOSTNAME}.config.system.build.sdImage" --impure
    echo "SD image at: $(readlink result)/sd-image/"
    ;;
  *)
    echo "Usage: $0 [build|switch|iso|sdimage] [options]"
    echo "  build             - Build configuration (default)"
    echo "                      hostname: stone|twink|server (or NIXOS_HOSTNAME=<hostname>)"
    echo "  switch            - Switch to new configuration"
    echo "                      hostname: stone|twink|server (or NIXOS_HOSTNAME=<hostname>)"
    echo "  iso --auto        - Build autoinstall ISO"
    echo "                      hostname: stone|twink|server (or NIXOS_HOSTNAME=<hostname>)"
    echo "  iso --live        - Build live-media interactive ISO"
    echo "                      hostname: server only"
    echo "  sdimage           - Build SD card image"
    echo "                      hostname: rpi2b|rpi3b-plus|rpi4b (or NIXOS_HOSTNAME=<hostname>)"
    echo ""
    echo "Current hostname: $HOSTNAME"
    exit 1
    ;;
esac
